# Copy to .env (or .env.local) and fill in real values.

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/global_landmark

# Admin panel — served only on the admin.<domain> subdomain.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
# Cloudinary (property image hosting). Empty = admin falls back to image-URL paste.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# newsdata.io (News page). Empty = /news renders a graceful fallback.
NEWSDATA_API_KEY=

# WhatsApp deep link target (country code + number, digits only).
NEXT_PUBLIC_WHATSAPP_NUMBER=

# The Gmail account that SENDS the email (also receives admin notifications)
GMAIL_USER=you@gmail.com

# App Password — NOT your Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on your Google account)
GMAIL_APP_PASSWORD=

# Public site URL — used for SEO metadata, sitemap, robots
NEXT_PUBLIC_SITE_URL=http://localhost:3000
